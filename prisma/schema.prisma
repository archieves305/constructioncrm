// ─── Roof Estimates ─────────────────────────────────────────────────────────

enum RoofMaterial {
  SHINGLE
  TILE
  METAL
  FLAT
}

// Singleton (id="default") with company branding + per-proposal defaults
// for the customer-facing roofing proposal PDF. Editable from /admin/roofing-brand.
model RoofingBrand {
  id                              String   @id @default("default")
  companyName                     String   @map("company_name")
  addressLine1                    String?  @map("address_line_1")
  addressLine2                    String?  @map("address_line_2")
  city                            String?
  state                           String?
  zip                             String?
  phone                           String?
  email                           String?
  website                         String?
  roofingLicense                  String?  @map("roofing_license")
  gcLicense                       String?  @map("gc_license")
  logoStorageKey                  String?  @map("logo_storage_key")
  defaultExpirationDays           Int      @default(30) @map("default_expiration_days")
  defaultUnderlaymentType         String?  @map("default_underlayment_type")
  defaultPlywoodSheetsIncluded    Int      @default(3) @map("default_plywood_sheets_included")
  defaultAdditionalPlywoodPrice   Decimal  @default(85) @map("default_additional_plywood_price") @db.Decimal(12, 2)
  defaultWorkmanshipWarrantyYears Int      @default(10) @map("default_workmanship_warranty_years")
  defaultManufacturerWarranty     String?  @map("default_manufacturer_warranty")
  paymentDepositPercent           Decimal  @default(40) @map("payment_deposit_percent") @db.Decimal(5, 2)
  paymentProgressPercent          Decimal  @default(40) @map("payment_progress_percent") @db.Decimal(5, 2)
  paymentFinalPercent             Decimal  @default(20) @map("payment_final_percent") @db.Decimal(5, 2)
  updatedAt                       DateTime @updatedAt @map("updated_at")

  @@map("roofing_brand")
}

model RoofEstimate {
  id                       String   @id @default(cuid())
  leadId                   String   @map("lead_id")
  estimateNumber           String   @unique @map("estimate_number")
  // roofTypesJson: array of { material: RoofMaterial, squares: number, laborRatePerSquare: number }
  roofTypesJson            Json     @map("roof_types_json")
  materialCost             Decimal  @default(0) @map("material_cost") @db.Decimal(12, 2)
  materialSelection        String?  @map("material_selection") @db.Text
  // Customer-facing proposal fields (defaults pulled from RoofingBrand on form load)
  existingRoofType         String?  @map("existing_roof_type")
  proposedRoofTypeOverride String?  @map("proposed_roof_type_override")
  underlaymentType         String?  @map("underlayment_type")
  permitIncluded           Boolean  @default(true) @map("permit_included")
  projectDurationText      String?  @map("project_duration_text")
  plywoodSheetsIncluded    Int?     @map("plywood_sheets_included")
  additionalPlywoodPrice   Decimal? @map("additional_plywood_price") @db.Decimal(12, 2)
  workmanshipWarrantyYears Int?     @map("workmanship_warranty_years")
  manufacturerWarranty     String?  @map("manufacturer_warranty")
  isEstimateOnly           Boolean  @default(false) @map("is_estimate_only")
  permitFee                Decimal  @default(0) @map("permit_fee") @db.Decimal(12, 2)
  dumpsterFee              Decimal  @default(0) @map("dumpster_fee") @db.Decimal(12, 2)
  tearOffFee               Decimal  @default(0) @map("tear_off_fee") @db.Decimal(12, 2)
  deckingFee               Decimal  @default(0) @map("decking_fee") @db.Decimal(12, 2)
  underlaymentFee          Decimal  @default(0) @map("underlayment_fee") @db.Decimal(12, 2)
  flashingVentFee          Decimal  @default(0) @map("flashing_vent_fee") @db.Decimal(12, 2)
  skylightChimneyFee       Decimal  @default(0) @map("skylight_chimney_fee") @db.Decimal(12, 2)
  guttersFee               Decimal  @default(0) @map("gutters_fee") @db.Decimal(12, 2)
  miscLabel                String?  @map("misc_label")
  miscFee                  Decimal  @default(0) @map("misc_fee") @db.Decimal(12, 2)
  marginPercent            Decimal  @default(0) @map("margin_percent") @db.Decimal(6, 3)
  discountEnabled          Boolean  @default(false) @map("discount_enabled")
  discountPercent          Decimal  @default(0) @map("discount_percent") @db.Decimal(6, 3)
  salesTaxPercent          Decimal  @default(0) @map("sales_tax_percent") @db.Decimal(6, 3)
  validityDays             Int      @default(30) @map("validity_days")
  specialTerms             String?  @map("special_terms") @db.Text
  subtotalCost             Decimal  @map("subtotal_cost") @db.Decimal(12, 2)
  totalPrice               Decimal  @map("total_price") @db.Decimal(12, 2)
  createdByUserId          String   @map("created_by_user_id")
  createdAt                DateTime @default(now()) @map("created_at")
  updatedAt                DateTime @updatedAt @map("updated_at")

  lead      Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)
  createdBy User @relation("RoofEstimateCreatedBy", fields: [createdByUserId], references: [id])

  @@index([leadId])
  @@map("roof_estimates")
}

enum RoofrOrderStatus {
  REQUESTED
  COMPLETED
  CANCELLED
  FAILED
}

model RoofrOrder {
  id              String           @id @default(cuid())
  leadId          String           @map("lead_id")
  status          RoofrOrderStatus @default(REQUESTED)
  externalOrderId String?          @map("external_order_id")
  reportUrl       String?          @map("report_url")
  notes           String?          @db.Text
  errorMessage    String?          @map("error_message") @db.Text
  requestedAt     DateTime         @default(now()) @map("requested_at")
  completedAt     DateTime?        @map("completed_at")
  createdByUserId String           @map("created_by_user_id")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")

  lead      Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)
  createdBy User @relation("RoofrOrderCreatedBy", fields: [createdByUserId], references: [id])

  @@index([leadId])
  @@map("roofr_orders")
}

// ─── Zylow property cache ─────────────────────────────────────────────────────
// Local mirror of zylow.net's read-only property API (canonical shape). We serve
// from here and refresh from Zylow on a ~24h TTL — never call Zylow from the
// browser (the API key stays server-side). Keyed by REAPI's property id.
model ZylowProperty {
  reapiId              String    @id @map("reapi_id")
  address              String?
  city                 String?
  state                String?
  zip                  String?
  county               String?
  latitude             Decimal?  @db.Decimal(10, 7)
  longitude            Decimal?  @db.Decimal(10, 7)
  ownerName            String?   @map("owner_name")
  bedrooms             Int?
  bathrooms            Decimal?  @db.Decimal(4, 1)
  sqft                 Int?
  yearBuilt            Int?      @map("year_built")
  propertyType         String?   @map("property_type")
  roofType             String?   @map("roof_type")
  lastSaleDate         DateTime? @map("last_sale_date") @db.Date
  lastSaleAmount       Int?      @map("last_sale_amount")
  outstandingMortgages Int?      @map("outstanding_mortgages")
  estimatedValue       Int?      @map("estimated_value")
  cachedAtZylow        DateTime? @map("cached_at_zylow")
  fetchedAtLocal       DateTime  @default(now()) @updatedAt @map("fetched_at_local")

  @@index([state, city])
  @@index([latitude, longitude])
  @@map("zylow_property_cache")
}

// ─── Canvassing prospects ─────────────────────────────────────────────────────
// A prospect is the unit of door-to-door canvassing: a property (usually sourced
// from the Zylow API by GPS/address) that we knock and track BEFORE it becomes a
// CRM lead. Door-knock routes and knocks reference prospects; when a prospect is
// worth pursuing it's "promoted" into a Lead (leadId set, status PROMOTED).
enum ProspectStatus {
  NEW
  CONTACTED
  INTERESTED
  NOT_INTERESTED
  PROMOTED
  DEAD
}

model Prospect {
  id               String         @id @default(cuid())
  reapiId          String?        @map("reapi_id") // Zylow/REAPI property id, if sourced from there
  ownerName        String?        @map("owner_name")
  propertyAddress1 String         @map("property_address_1")
  propertyAddress2 String?        @map("property_address_2")
  city             String
  state            String         @default("FL")
  zipCode          String?        @map("zip_code")
  county           String?
  latitude         Decimal?       @db.Decimal(10, 7)
  longitude        Decimal?       @db.Decimal(10, 7)
  status           ProspectStatus @default(NEW)
  notes            String?        @db.Text
  assignedToUserId String?        @map("assigned_to_user_id")
  createdByUserId  String         @map("created_by_user_id")
  leadId           String?        @unique @map("lead_id") // set on promotion
  promotedAt       DateTime?      @map("promoted_at")
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")

  assignedTo User? @relation("ProspectAssignedTo", fields: [assignedToUserId], references: [id])
  createdBy  User  @relation("ProspectCreatedBy", fields: [createdByUserId], references: [id])
  lead       Lead? @relation(fields: [leadId], references: [id], onDelete: SetNull)

  knocks PropertyDoorKnock[]
  stops  DoorKnockRouteStop[]

  @@index([status])
  @@index([assignedToUserId])
  @@index([latitude, longitude])
  @@index([reapiId])
  @@map("prospects")
}

// ─── Canvassing lead scoring ──────────────────────────────────────────────────
// Enriched, scored property record powering the Find Properties "Knock Score" and
// the Canvasser One-Screen Summary. Sourced from the Zylow/REAPI data (keyed by
// reapiId, the same id Prospect.reapiId carries). The full upstream payload is
// kept in realapi_raw_json for re-scoring/reference; the most-used fields are
// normalized into columns for fast list/sort/display. last_realapi_sync_at drives
// the 30-day refresh rule (see CanvassingSettings.cacheTtlDays).
model CanvassingProperty {
  id                       String    @id @default(cuid())
  reapiId                  String    @unique @map("reapi_id")
  propertyAddress          String?   @map("property_address")
  city                     String?
  state                    String?
  zip                      String?
  ownerName                String?   @map("owner_name")
  mailingAddress           String?   @map("mailing_address")
  ownerOccupied            Boolean?  @map("owner_occupied")
  yearBuilt                Int?      @map("year_built")
  ownedSince               Int?      @map("owned_since")
  lastSaleDate             DateTime? @map("last_sale_date") @db.Date
  lastSalePrice            Int?      @map("last_sale_price")
  estimatedValue           Int?      @map("estimated_value")
  estimatedMortgageBalance Int?      @map("estimated_mortgage_balance")
  estimatedEquity          Int?      @map("estimated_equity")
  equityPercentage         Int?      @map("equity_percentage")
  lastRoofPermitDate       DateTime? @map("last_roof_permit_date") @db.Date
  estimatedRoofAge         Int?      @map("estimated_roof_age")
  roofType                 String?   @map("roof_type")
  propertyType             String?   @map("property_type")
  buildingSqft             Int?      @map("building_sqft")
  stories                  Int?
  lotSizeSqft              Int?      @map("lot_size_sqft")
  knockScore               Int       @default(0) @map("knock_score")
  knockScoreTier           String?   @map("knock_score_tier")
  recommendedOpening       String?   @map("recommended_opening") @db.Text
  canvasserSummaryJson     Json?     @map("canvasser_summary_json")
  realapiRawJson           Json?     @map("realapi_raw_json")
  lastRealapiSyncAt        DateTime? @map("last_realapi_sync_at")
  createdAt                DateTime  @default(now()) @map("created_at")
  updatedAt                DateTime  @updatedAt @map("updated_at")

  @@index([knockScore])
  @@index([state, city])
  @@map("canvassing_properties")
}

// Singleton (id = "default") admin configuration for canvassing lead scoring:
// the full per-rule Knock Score config (JSON), display/visibility toggles, the
// default opening script, and the compliance disclaimer. Mirrors the EmailBrand
// singleton pattern.
model CanvassingSettings {
  id                     String   @id @default("default")
  scoringConfigJson      Json     @map("scoring_config_json")
  minPriorityScore       Int      @default(50) @map("min_priority_score")
  showAbsenteeOwners     Boolean  @default(true) @map("show_absentee_owners")
  hideLowScoreProperties Boolean  @default(false) @map("hide_low_score_properties")
  cacheTtlDays           Int      @default(30) @map("cache_ttl_days")
  defaultOpeningScript   String   @map("default_opening_script") @db.Text
  complianceDisclaimer   String   @map("compliance_disclaimer") @db.Text
  createdAt              DateTime @default(now()) @map("created_at")
  updatedAt              DateTime @updatedAt @map("updated_at")

  @@map("canvassing_settings")
}

// ─── Generic Estimate Engine (template-driven, non-roofing) ──────────────────
// Roofing keeps its specialized RoofEstimate model above. These tables power
// the template-driven estimate builder for Drywall, Interior Renovation, and
// Windows & Doors (and any future trade), with sectioned line items + units.

enum EstimateTemplateCategory {
  ROOFING
  DRYWALL
  INTERIOR_RENOVATION
  WINDOWS_DOORS
}

enum EstimateUnitType {
  EACH
  OPENING
  SHEET
  SQ_FT
  LINEAR_FT
  ROOM
  LUMP_SUM
  LABOR_HOUR
}

enum EstimateStatus {
  DRAFT
  SENT
  ACCEPTED
  DECLINED
}

model EstimateTemplate {
  id        String                   @id @default(cuid())
  key       String                   @unique
  category  EstimateTemplateCategory
  name      String
  isActive  Boolean                  @default(true) @map("is_active")
  sortOrder Int                      @default(0) @map("sort_order")
  createdAt DateTime                 @default(now()) @map("created_at")
  updatedAt DateTime                 @updatedAt @map("updated_at")

  sections  EstimateTemplateSection[]
  estimates Estimate[]

  @@map("estimate_templates")
}

model EstimateTemplateSection {
  id         String   @id @default(cuid())
  templateId String   @map("template_id")
  title      String
  sortOrder  Int      @default(0) @map("sort_order")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  template EstimateTemplate           @relation(fields: [templateId], references: [id], onDelete: Cascade)
  items    EstimateTemplateLineItem[]

  @@index([templateId])
  @@map("estimate_template_sections")
}

model EstimateTemplateLineItem {
  id               String           @id @default(cuid())
  sectionId        String           @map("section_id")
  description      String
  unitType         EstimateUnitType @map("unit_type")
  defaultQuantity  Decimal?         @map("default_quantity") @db.Decimal(12, 2)
  defaultUnitPrice Decimal?         @map("default_unit_price") @db.Decimal(12, 2)
  defaultNotes     String?          @map("default_notes") @db.Text
  isOptional       Boolean          @default(false) @map("is_optional")
  isActive         Boolean          @default(true) @map("is_active")
  sortOrder        Int              @default(0) @map("sort_order")
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")

  section EstimateTemplateSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  @@index([sectionId])
  @@map("estimate_template_line_items")
}

model Estimate {
  id               String                   @id @default(cuid())
  leadId           String                   @map("lead_id")
  templateId       String?                  @map("template_id")
  templateCategory EstimateTemplateCategory @map("template_category")
  estimateNumber   String                   @unique @map("estimate_number")
  name             String
  status           EstimateStatus           @default(DRAFT)
  marginPercent    Decimal                  @default(0) @map("margin_percent") @db.Decimal(6, 3)
  discountEnabled  Boolean                  @default(false) @map("discount_enabled")
  discountPercent  Decimal                  @default(0) @map("discount_percent") @db.Decimal(6, 3)
  salesTaxPercent  Decimal                  @default(0) @map("sales_tax_percent") @db.Decimal(6, 3)
  validityDays     Int                      @default(30) @map("validity_days")
  notes            String?                  @db.Text
  exclusions       String?                  @db.Text
  subtotalCost     Decimal                  @map("subtotal_cost") @db.Decimal(12, 2)
  totalPrice       Decimal                  @map("total_price") @db.Decimal(12, 2)
  createdByUserId  String                   @map("created_by_user_id")
  createdAt        DateTime                 @default(now()) @map("created_at")
  updatedAt        DateTime                 @updatedAt @map("updated_at")

  lead      Lead              @relation(fields: [leadId], references: [id], onDelete: Cascade)
  template  EstimateTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  createdBy User              @relation("EstimateCreatedBy", fields: [createdByUserId], references: [id])
  sections  EstimateSection[]

  @@index([leadId])
  @@index([templateCategory])
  @@map("estimates")
}

model EstimateSection {
  id         String   @id @default(cuid())
  estimateId String   @map("estimate_id")
  title      String
  sortOrder  Int      @default(0) @map("sort_order")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  estimate Estimate           @relation(fields: [estimateId], references: [id], onDelete: Cascade)
  items    EstimateLineItem[]

  @@index([estimateId])
  @@map("estimate_sections")
}

model EstimateLineItem {
  id          String           @id @default(cuid())
  sectionId   String           @map("section_id")
  description String
  unitType    EstimateUnitType @map("unit_type")
  quantity    Decimal          @default(0) @db.Decimal(12, 2)
  unitPrice   Decimal          @default(0) @map("unit_price") @db.Decimal(12, 2)
  lineTotal   Decimal          @default(0) @map("line_total") @db.Decimal(12, 2)
  isOptional  Boolean          @default(false) @map("is_optional")
  notes       String?          @db.Text
  sortOrder   Int              @default(0) @map("sort_order")
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")

  section EstimateSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  @@index([sectionId])
  @@map("estimate_line_items")
}
