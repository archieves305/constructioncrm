generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ──────────────────────────────────────────────────────────────────

enum RoleName {
  ADMIN
  MANAGER
  SALES_REP
  OFFICE_STAFF
  MARKETING
  READ_ONLY
}

enum PropertyType {
  RESIDENTIAL
  COMMERCIAL
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum ActivityType {
  NOTE
  STAGE_CHANGE
  ASSIGNMENT_CHANGE
  TASK_CREATED
  TASK_COMPLETED
  CALL_LOGGED
  SMS_LOGGED
  EMAIL_LOGGED
  PERMIT_ADDED
  FILE_UPLOADED
  LEAD_CREATED
  LEAD_UPDATED
  JOB_CREATED
  JOB_STAGE_CHANGE
  PAYMENT_RECEIVED
  CREW_ASSIGNED
  INSPECTION_SCHEDULED
  INSPECTION_COMPLETED
  REVIEW_REQUESTED
  REFERRAL_CREATED
}

enum PaymentType {
  DEPOSIT
  PROGRESS
  FINAL
  FINANCING_FUNDING
}

enum PaymentStatus {
  PENDING
  RECEIVED
  OVERDUE
  WAIVED
  REFUNDED
}

enum PaymentMethod {
  CHECK
  CARD
  ACH
  CASH
  FINANCING
  WIRE
  OTHER
}

enum JobType {
  FIXED_PRICE
  COST_PLUS
  OWNED_REHAB
}

enum MarginType {
  PERCENT
  FLAT
}

enum FinancingStatus {
  NOT_NEEDED
  PENDING_APPLICATION
  SUBMITTED
  APPROVED
  DENIED
  FUNDED
}

enum InspectionResult {
  PENDING
  PASSED
  FAILED
  PARTIAL
  RESCHEDULED
}

enum ReviewStatus {
  PENDING
  SENT
  COMPLETED
  DECLINED
}

enum ReferralStatus {
  NEW
  CONTACTED
  CONVERTED
  DECLINED
}

enum EmailProcessingStatus {
  PENDING
  PROCESSING
  PARSED
  LEAD_CREATED
  DUPLICATE
  IGNORED
  FAILED
}

enum NotificationChannel {
  SMS
  EMAIL
  IN_APP
}

enum NotificationStatus {
  QUEUED
  SENT
  DELIVERED
  FAILED
  CLICKED
}

enum TrackedActionType {
  OPEN_LEAD
  ACKNOWLEDGE
  START_CALL
  MARK_ATTEMPTED
  MARK_CONTACTED
}

enum CommunicationType {
  SMS
  CALL
  EMAIL
}

enum CommunicationDirection {
  INBOUND
  OUTBOUND
}

enum CommunicationStatus {
  PENDING
  SENT
  DELIVERED
  FAILED
  RECEIVED
}

enum ChannelType {
  PAID
  ORGANIC
  REFERRAL
  DIRECT
  SOCIAL
  OTHER
}

enum FileCategory {
  PHOTOS
  ESTIMATE
  PERMIT
  SIGNED_DOC
  INSURANCE
  INSPECTION
  LABOR_CONTRACT
  INTERIOR_RENOVATION_LABOR_CONTRACT
  CONTRACT_ADDENDUM
  OTHER
}

enum GeneratedDocumentType {
  LABOR_CONTRACT
  INTERIOR_RENOVATION_LABOR_CONTRACT
  CONTRACT_ADDENDUM
}

enum DoorKnockOutcome {
  NO_ANSWER
  SPOKE_WITH_OWNER
  SPOKE_WITH_OCCUPANT
  LEFT_DOOR_HANGER
  VACANT
  HOSTILE
  GATE_BLOCKED
  OTHER
}

enum DoorKnockRouteStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
  ARCHIVED
}

enum DoorKnockStopStatus {
  PENDING
  VISITED
  SKIPPED
}

enum PermitStatus {
  APPLIED
  ISSUED
  IN_PROGRESS
  FINAL
  EXPIRED
  DENIED
  UNKNOWN
}

enum PermitInspectionType {
  ROUGH
  FRAMING
  ELECTRICAL
  PLUMBING
  MECHANICAL
  ROOFING_IN_PROGRESS
  ROOFING_FINAL
  FINAL
  OTHER
}

enum PermitInspectionResult {
  SCHEDULED
  PASS
  FAIL
  CONDITIONAL
  CANCELLED
}

enum LookupStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  FAILED
}

// ─── Core Tables ────────────────────────────────────────────────────────────

model Role {
  id          String   @id @default(cuid())
  name        RoleName @unique
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  users User[]

  @@map("roles")
}

model User {
  id           String   @id @default(cuid())
  firstName    String   @map("first_name")
  lastName     String   @map("last_name")
  email        String   @unique
  passwordHash String   @map("password_hash")
  roleId       String   @map("role_id")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  role Role @relation(fields: [roleId], references: [id])

  assignedLeads            Lead[]               @relation("AssignedUser")
  createdLeads             Lead[]               @relation("CreatedByUser")
  assignmentsGiven         LeadAssignment[]     @relation("AssignedByUser")
  assignmentsOwned         LeadAssignment[]     @relation("AssignedToUser")
  stageChanges             LeadStageHistory[]   @relation("ChangedByUser")
  tasksAssigned            Task[]               @relation("TaskAssignedUser")
  tasksCreated             Task[]               @relation("TaskCreatedByUser")
  activityLogs             ActivityLog[]
  communications           Communication[]
  filesUploaded            File[]
  permitLookupRuns         PermitLookupRun[]
  managedJobs              Job[]                @relation("ProjectManager")
  soldJobs                 Job[]                @relation("SalesRep")
  jobStageChanges          JobStageHistory[]    @relation("JobChangedByUser")
  assignedPermits          JobPermit[]          @relation("PermitAssignedUser")
  inspections              Inspection[]
  passwordResetTokens      PasswordResetToken[]
  notifications            NotificationEvent[]
  expensesCreated          JobExpense[]
  jobTaskTemplatesDefault  JobTaskTemplate[]
  auditEvents              AuditEvent[]
  roofEstimatesCreated     RoofEstimate[]       @relation("RoofEstimateCreatedBy")
  estimatesCreated         Estimate[]           @relation("EstimateCreatedBy")
  roofrOrdersCreated       RoofrOrder[]         @relation("RoofrOrderCreatedBy")
  doorKnocksCreated        PropertyDoorKnock[]  @relation("DoorKnockKnockedBy")
  doorKnocksDeleted        PropertyDoorKnock[]  @relation("DoorKnockDeletedBy")
  doorKnockRoutesCreated   DoorKnockRoute[]     @relation("DoorKnockRouteCreatedBy")
  doorKnockRoutesAssigned  DoorKnockRoute[]     @relation("DoorKnockRouteAssignedTo")
  prospectsCreated         Prospect[]           @relation("ProspectCreatedBy")
  prospectsAssigned        Prospect[]           @relation("ProspectAssignedTo")
  laborContractsCreated    LaborContract[]
  laborPaymentsCreated     LaborPayment[]
  laborChangeOrdersCreated LaborChangeOrder[]
  changeOrdersCreated      ChangeOrder[]
  generatedDocuments       GeneratedDocument[]

  signatureHtml String? @map("signature_html") @db.Text
  signatureText String? @map("signature_text") @db.Text

  @@map("users")
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String    @map("user_id")
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

// ─── Lead Management ────────────────────────────────────────────────────────

model LeadSource {
  id          String      @id @default(cuid())
  name        String
  parentId    String?     @map("parent_id")
  channelType ChannelType @default(OTHER) @map("channel_type")
  isActive    Boolean     @default(true) @map("is_active")
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  parent   LeadSource?  @relation("SourceHierarchy", fields: [parentId], references: [id])
  children LeadSource[] @relation("SourceHierarchy")
  leads    Lead[]

  @@map("lead_sources")
}

model ServiceCategory {
  id        String   @id @default(cuid())
  name      String
  parentId  String?  @map("parent_id")
  isActive  Boolean  @default(true) @map("is_active")
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  parent       ServiceCategory?  @relation("ServiceHierarchy", fields: [parentId], references: [id])
  children     ServiceCategory[] @relation("ServiceHierarchy")
  leadServices LeadService[]

  @@map("service_categories")
}

model LeadStage {
  id         String   @id @default(cuid())
  name       String   @unique
  stageOrder Int      @map("stage_order")
  isClosed   Boolean  @default(false) @map("is_closed")
  isWon      Boolean  @default(false) @map("is_won")
  isLost     Boolean  @default(false) @map("is_lost")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  leads         Lead[]
  historyFrom   LeadStageHistory[] @relation("FromStage")
  historyTo     LeadStageHistory[] @relation("ToStage")
  followUpRules FollowUpRule[]     @relation("FollowUpRuleTargetStage")

  @@map("lead_stages")
}

model Lead {
  id                     String       @id @default(cuid())
  firstName              String       @map("first_name")
  lastName               String       @map("last_name")
  fullName               String       @map("full_name")
  companyName            String?      @map("company_name")
  primaryPhone           String       @map("primary_phone")
  secondaryPhone         String?      @map("secondary_phone")
  email                  String?
  propertyAddress1       String       @map("property_address_1")
  propertyAddress2       String?      @map("property_address_2")
  mailingAddress1        String?      @map("mailing_address_1")
  mailingAddress2        String?      @map("mailing_address_2")
  city                   String
  county                 String?
  state                  String       @default("FL")
  zipCode                String       @map("zip_code")
  propertyType           PropertyType @default(RESIDENTIAL) @map("property_type")
  sourceId               String?      @map("source_id")
  sourceDetail           String?      @map("source_detail")
  assignedUserId         String?      @map("assigned_user_id")
  currentStageId         String       @map("current_stage_id")
  estimatedJobValue      Decimal?     @map("estimated_job_value") @db.Decimal(12, 2)
  residentialCommercial  String?      @map("residential_commercial")
  insuranceClaim         Boolean      @default(false) @map("insurance_claim")
  financingNeeded        Boolean      @default(false) @map("financing_needed")
  urgent                 Boolean      @default(false)
  preferredContactMethod String?      @map("preferred_contact_method")
  notesSummary           String?      @map("notes_summary") @db.Text
  lastContactAt          DateTime?    @map("last_contact_at")
  nextFollowUpAt         DateTime?    @map("next_follow_up_at")
  isDuplicateFlag        Boolean      @default(false) @map("is_duplicate_flag")
  duplicateGroupId       String?      @map("duplicate_group_id")
  emailOptedOut          Boolean      @default(false) @map("email_opted_out")
  emailOptedOutAt        DateTime?    @map("email_opted_out_at")
  createdByUserId        String       @map("created_by_user_id")
  createdAt              DateTime     @default(now()) @map("created_at")
  updatedAt              DateTime     @updatedAt @map("updated_at")

  source       LeadSource? @relation(fields: [sourceId], references: [id])
  assignedUser User?       @relation("AssignedUser", fields: [assignedUserId], references: [id])
  currentStage LeadStage   @relation(fields: [currentStageId], references: [id])
  createdBy    User        @relation("CreatedByUser", fields: [createdByUserId], references: [id])

  services       LeadService[]
  stageHistory   LeadStageHistory[]
  assignments    LeadAssignment[]
  tasks          Task[]
  activityLogs   ActivityLog[]
  communications Communication[]
  permits        Permit[]
  permitLookups  PermitLookupRun[]
  files          File[]
  jobs           Job[]
  reviewRequests ReviewRequest[]
  referrals      Referral[]
  notifications  NotificationEvent[]
  followUps      FollowUpExecution[]
  roofEstimates  RoofEstimate[]
  estimates      Estimate[]
  roofrOrders    RoofrOrder[]
  prospect       Prospect?

  @@index([primaryPhone])
  @@index([email])
  @@index([propertyAddress1, city, zipCode])
  @@index([assignedUserId])
  @@index([currentStageId])
  @@index([sourceId])
  @@index([nextFollowUpAt])
  @@index([createdAt])
  @@map("leads")
}

model LeadService {
  id                String   @id @default(cuid())
  leadId            String   @map("lead_id")
  serviceCategoryId String   @map("service_category_id")
  createdAt         DateTime @default(now()) @map("created_at")

  lead            Lead            @relation(fields: [leadId], references: [id], onDelete: Cascade)
  serviceCategory ServiceCategory @relation(fields: [serviceCategoryId], references: [id])

  @@unique([leadId, serviceCategoryId])
  @@map("lead_services")
}

model LeadStageHistory {
  id              String   @id @default(cuid())
  leadId          String   @map("lead_id")
  fromStageId     String?  @map("from_stage_id")
  toStageId       String   @map("to_stage_id")
  changedByUserId String   @map("changed_by_user_id")
  changedAt       DateTime @default(now()) @map("changed_at")
  reason          String?

  lead      Lead       @relation(fields: [leadId], references: [id], onDelete: Cascade)
  fromStage LeadStage? @relation("FromStage", fields: [fromStageId], references: [id])
  toStage   LeadStage  @relation("ToStage", fields: [toStageId], references: [id])
  changedBy User       @relation("ChangedByUser", fields: [changedByUserId], references: [id])

  @@index([leadId])
  @@index([changedAt])
  @@map("lead_stage_history")
}

model LeadAssignment {
  id               String    @id @default(cuid())
  leadId           String    @map("lead_id")
  assignedUserId   String    @map("assigned_user_id")
  assignedByUserId String    @map("assigned_by_user_id")
  assignedAt       DateTime  @default(now()) @map("assigned_at")
  unassignedAt     DateTime? @map("unassigned_at")
  reason           String?

  lead       Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)
  assignedTo User @relation("AssignedToUser", fields: [assignedUserId], references: [id])
  assignedBy User @relation("AssignedByUser", fields: [assignedByUserId], references: [id])

  @@index([leadId])
  @@map("lead_assignments")
}

// ─── Tasks ──────────────────────────────────────────────────────────────────

model Task {
  id              String     @id @default(cuid())
  leadId          String?    @map("lead_id")
  jobId           String?    @map("job_id")
  title           String
  description     String?    @db.Text
  assignedUserId  String?    @map("assigned_user_id")
  createdByUserId String     @map("created_by_user_id")
  dueAt           DateTime?  @map("due_at")
  priority        Priority   @default(MEDIUM)
  status          TaskStatus @default(PENDING)
  completedAt     DateTime?  @map("completed_at")
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")

  lead       Lead? @relation(fields: [leadId], references: [id], onDelete: SetNull)
  job        Job?  @relation(fields: [jobId], references: [id], onDelete: SetNull)
  assignedTo User? @relation("TaskAssignedUser", fields: [assignedUserId], references: [id])
  createdBy  User  @relation("TaskCreatedByUser", fields: [createdByUserId], references: [id])

  @@index([assignedUserId])
  @@index([dueAt])
  @@index([status])
  @@map("tasks")
}

// ─── Activity Log ───────────────────────────────────────────────────────────

model ActivityLog {
  id              String       @id @default(cuid())
  leadId          String       @map("lead_id")
  activityType    ActivityType @map("activity_type")
  title           String
  description     String?      @db.Text
  metadataJson    Json?        @map("metadata_json")
  createdByUserId String?      @map("created_by_user_id")
  createdAt       DateTime     @default(now()) @map("created_at")

  lead      Lead  @relation(fields: [leadId], references: [id], onDelete: Cascade)
  createdBy User? @relation(fields: [createdByUserId], references: [id])

  @@index([leadId])
  @@index([createdAt])
  @@map("activity_logs")
}

// ─── Communications ─────────────────────────────────────────────────────────

model Communication {
  id                String                 @id @default(cuid())
  leadId            String                 @map("lead_id")
  communicationType CommunicationType      @map("communication_type")
  direction         CommunicationDirection
  provider          String?
  externalMessageId String?                @map("external_message_id")
  fromValue         String                 @map("from_value")
  toValue           String                 @map("to_value")
  subject           String?
  body              String                 @db.Text
  status            CommunicationStatus    @default(PENDING)
  sentAt            DateTime?              @map("sent_at")
  receivedAt        DateTime?              @map("received_at")
  createdByUserId   String?                @map("created_by_user_id")
  createdAt         DateTime               @default(now()) @map("created_at")

  lead      Lead  @relation(fields: [leadId], references: [id], onDelete: Cascade)
  createdBy User? @relation(fields: [createdByUserId], references: [id])

  @@index([leadId])
  @@map("communications")
}

// ─── Permits ────────────────────────────────────────────────────────────────

model Permit {
  id                String       @id @default(cuid())
  leadId            String?      @map("lead_id")
  addressNormalized String       @map("address_normalized")
  municipality      String
  sourceSystem      String?      @map("source_system")
  permitNumber      String?      @map("permit_number")
  permitType        String?      @map("permit_type")
  permitDescription String?      @map("permit_description") @db.Text
  permitStatus      PermitStatus @default(UNKNOWN) @map("permit_status")
  contractorName    String?      @map("contractor_name")
  ownerName         String?      @map("owner_name")
  issueDate         DateTime?    @map("issue_date")
  finalDate         DateTime?    @map("final_date")
  lastCheckedAt     DateTime?    @map("last_checked_at")
  rawDataJson       Json?        @map("raw_data_json")
  createdAt         DateTime     @default(now()) @map("created_at")
  updatedAt         DateTime     @updatedAt @map("updated_at")

  lead Lead? @relation(fields: [leadId], references: [id], onDelete: SetNull)

  @@index([leadId])
  @@index([addressNormalized])
  @@map("permits")
}

model PermitLookupRun {
  id              String       @id @default(cuid())
  leadId          String?      @map("lead_id")
  lookupAddress   String       @map("lookup_address")
  municipality    String
  connectorName   String       @map("connector_name")
  status          LookupStatus @default(PENDING)
  startedAt       DateTime     @default(now()) @map("started_at")
  completedAt     DateTime?    @map("completed_at")
  errorMessage    String?      @map("error_message") @db.Text
  responseSummary String?      @map("response_summary") @db.Text
  createdByUserId String?      @map("created_by_user_id")

  lead      Lead? @relation(fields: [leadId], references: [id], onDelete: SetNull)
  createdBy User? @relation(fields: [createdByUserId], references: [id])

  @@index([leadId])
  @@map("permit_lookup_runs")
}

// ─── Files ──────────────────────────────────────────────────────────────────

model File {
  id               String       @id @default(cuid())
  leadId           String       @map("lead_id")
  fileName         String       @map("file_name")
  fileType         String       @map("file_type")
  storageKey       String       @map("storage_key")
  fileSize         Int          @map("file_size")
  category         FileCategory @default(OTHER)
  uploadedByUserId String       @map("uploaded_by_user_id")
  doorKnockId      String?      @map("door_knock_id")
  createdAt        DateTime     @default(now()) @map("created_at")

  lead               Lead                @relation(fields: [leadId], references: [id], onDelete: Cascade)
  uploadedBy         User                @relation(fields: [uploadedByUserId], references: [id])
  doorKnock          PropertyDoorKnock?  @relation(fields: [doorKnockId], references: [id], onDelete: SetNull)
  generatedDocuments GeneratedDocument[]

  @@index([leadId])
  @@index([doorKnockId])
  @@map("files")
}

// ─── Door Knock / Canvassing ────────────────────────────────────────────────

model PropertyDoorKnock {
  id              String           @id @default(cuid())
  prospectId      String           @map("prospect_id")
  outcome         DoorKnockOutcome
  notes           String?          @db.Text
  latitude        Decimal?         @db.Decimal(10, 7)
  longitude       Decimal?         @db.Decimal(10, 7)
  accuracyMeters  Decimal?         @map("accuracy_meters") @db.Decimal(7, 2)
  knockedAt       DateTime         @default(now()) @map("knocked_at")
  knockedByUserId String           @map("knocked_by_user_id")
  isDeleted       Boolean          @default(false) @map("is_deleted")
  deletedAt       DateTime?        @map("deleted_at")
  deletedByUserId String?          @map("deleted_by_user_id")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")

  prospect  Prospect @relation(fields: [prospectId], references: [id], onDelete: Cascade)
  knockedBy User     @relation("DoorKnockKnockedBy", fields: [knockedByUserId], references: [id])
  deletedBy User?    @relation("DoorKnockDeletedBy", fields: [deletedByUserId], references: [id])

  photos     File[]
  routeStops DoorKnockRouteStop[]

  @@index([prospectId, knockedAt(sort: Desc)])
  @@index([knockedByUserId, knockedAt(sort: Desc)])
  @@index([isDeleted])
  @@map("property_door_knocks")
}

model DoorKnockRoute {
  id                 String               @id @default(cuid())
  name               String
  description        String?              @db.Text
  status             DoorKnockRouteStatus @default(PLANNED)
  scheduledFor       DateTime?            @map("scheduled_for") @db.Date
  totalDistanceMiles Decimal?             @map("total_distance_miles") @db.Decimal(8, 2)
  startLatitude      Decimal?             @map("start_latitude") @db.Decimal(10, 7)
  startLongitude     Decimal?             @map("start_longitude") @db.Decimal(10, 7)
  startLabel         String?              @map("start_label")
  isRoundTrip        Boolean              @default(true) @map("is_round_trip")
  createdByUserId    String               @map("created_by_user_id")
  assignedToUserId   String?              @map("assigned_to_user_id")
  isDeleted          Boolean              @default(false) @map("is_deleted")
  createdAt          DateTime             @default(now()) @map("created_at")
  updatedAt          DateTime             @updatedAt @map("updated_at")

  createdBy  User  @relation("DoorKnockRouteCreatedBy", fields: [createdByUserId], references: [id])
  assignedTo User? @relation("DoorKnockRouteAssignedTo", fields: [assignedToUserId], references: [id])

  stops DoorKnockRouteStop[]

  @@index([status, isDeleted])
  @@index([assignedToUserId])
  @@index([createdByUserId])
  @@map("door_knock_routes")
}

model DoorKnockRouteStop {
  id         String              @id @default(cuid())
  routeId    String              @map("route_id")
  prospectId String              @map("prospect_id")
  sortOrder  Int                 @map("sort_order")
  status     DoorKnockStopStatus @default(PENDING)
  knockId    String?             @map("knock_id")
  notes      String?             @db.Text
  createdAt  DateTime            @default(now()) @map("created_at")
  updatedAt  DateTime            @updatedAt @map("updated_at")

  route    DoorKnockRoute     @relation(fields: [routeId], references: [id], onDelete: Cascade)
  prospect Prospect           @relation(fields: [prospectId], references: [id], onDelete: Cascade)
  knock    PropertyDoorKnock? @relation(fields: [knockId], references: [id], onDelete: SetNull)

  @@unique([routeId, prospectId])
  @@index([routeId, sortOrder])
  @@map("door_knock_route_stops")
}

// ─── Automation (Future) ────────────────────────────────────────────────────

model FollowUpRule {
  id                String   @id @default(cuid())
  name              String
  triggerEvent      String   @map("trigger_event")
  targetStageId     String?  @map("target_stage_id")
  delayMinutes      Int      @map("delay_minutes")
  messageTemplateId String?  @map("message_template_id")
  taskTemplateJson  Json?    @map("task_template_json")
  isActive          Boolean  @default(true) @map("is_active")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  messageTemplate MessageTemplate?    @relation(fields: [messageTemplateId], references: [id])
  targetStage     LeadStage?          @relation("FollowUpRuleTargetStage", fields: [targetStageId], references: [id])
  executions      FollowUpExecution[]

  @@index([triggerEvent, isActive])
  @@index([targetStageId])
  @@map("follow_up_rules")
}

enum FollowUpExecutionStatus {
  PENDING
  SENT
  FAILED
  CANCELLED
}

model FollowUpExecution {
  id           String                  @id @default(cuid())
  ruleId       String                  @map("rule_id")
  leadId       String                  @map("lead_id")
  permitId     String?                 @map("permit_id")
  inspectionId String?                 @map("inspection_id")
  scheduledAt  DateTime                @map("scheduled_at")
  executedAt   DateTime?               @map("executed_at")
  status       FollowUpExecutionStatus @default(PENDING)
  errorMessage String?                 @map("error_message")
  attemptCount Int                     @default(0) @map("attempt_count")
  createdAt    DateTime                @default(now()) @map("created_at")
  updatedAt    DateTime                @updatedAt @map("updated_at")

  rule       FollowUpRule         @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  lead       Lead                 @relation(fields: [leadId], references: [id], onDelete: Cascade)
  permit     JobPermit?           @relation(fields: [permitId], references: [id], onDelete: SetNull)
  inspection JobPermitInspection? @relation(fields: [inspectionId], references: [id], onDelete: SetNull)

  @@index([status, scheduledAt])
  @@index([leadId])
  @@index([permitId])
  @@index([inspectionId])
  @@map("follow_up_executions")
}

model MessageTemplate {
  id           String   @id @default(cuid())
  name         String
  channel      String
  templateBody String   @map("template_body") @db.Text
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  followUpRules FollowUpRule[]

  @@map("message_templates")
}

model DashboardMetricSnapshot {
  id           String   @id @default(cuid())
  snapshotDate DateTime @map("snapshot_date") @db.Date
  metricName   String   @map("metric_name")
  metricValue  Decimal  @map("metric_value") @db.Decimal(18, 4)
  metadataJson Json?    @map("metadata_json")
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([snapshotDate, metricName])
  @@map("dashboard_metric_snapshots")
}

// ─── CRM 2.0: Jobs + Production ─────────────────────────────────────────────

model JobStage {
  id         String   @id @default(cuid())
  name       String   @unique
  stageOrder Int      @map("stage_order")
  isClosed   Boolean  @default(false) @map("is_closed")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  jobs          Job[]
  historyFrom   JobStageHistory[] @relation("JobFromStage")
  historyTo     JobStageHistory[] @relation("JobToStage")
  taskTemplates JobTaskTemplate[]

  @@map("job_stages")
}

model JobTaskTemplate {
  id                    String   @id @default(cuid())
  stageId               String   @map("stage_id")
  title                 String
  description           String?  @db.Text
  priority              Priority @default(MEDIUM)
  relativeDueInDays     Int?     @map("relative_due_in_days")
  defaultAssignedUserId String?  @map("default_assigned_user_id")
  isActive              Boolean  @default(true) @map("is_active")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  stage           JobStage @relation(fields: [stageId], references: [id], onDelete: Cascade)
  defaultAssignee User?    @relation(fields: [defaultAssignedUserId], references: [id])

  @@index([stageId, isActive])
  @@map("job_task_templates")
}

model Job {
  id                    String          @id @default(cuid())
  leadId                String          @map("lead_id")
  jobNumber             String          @unique @map("job_number")
  title                 String
  serviceType           String          @map("service_type")
  jobType               JobType         @default(FIXED_PRICE) @map("job_type")
  laborCost             Decimal?        @map("labor_cost") @db.Decimal(12, 2)
  marginType            MarginType?     @map("margin_type")
  marginValue           Decimal?        @map("margin_value") @db.Decimal(12, 2)
  contractAmount        Decimal         @map("contract_amount") @db.Decimal(12, 2)
  depositRequired       Decimal         @default(0) @map("deposit_required") @db.Decimal(12, 2)
  depositReceived       Decimal         @default(0) @map("deposit_received") @db.Decimal(12, 2)
  depositReceivedDate   DateTime?       @map("deposit_received_date")
  financingRequired     Boolean         @default(false) @map("financing_required")
  financingProvider     String?         @map("financing_provider")
  financingStatus       FinancingStatus @default(NOT_NEEDED) @map("financing_status")
  financingApprovedDate DateTime?       @map("financing_approved_date")
  balanceDue            Decimal         @default(0) @map("balance_due") @db.Decimal(12, 2)
  finalPaymentReceived  Boolean         @default(false) @map("final_payment_received")
  finalPaymentDate      DateTime?       @map("final_payment_date")
  projectManagerId      String?         @map("project_manager_id")
  salesRepId            String?         @map("sales_rep_id")
  currentStageId        String          @map("current_stage_id")
  nextAction            String?         @map("next_action")
  targetStartDate       DateTime?       @map("target_start_date")
  scheduledDate         DateTime?       @map("scheduled_date")
  completionDate        DateTime?       @map("completion_date")
  isRentalTurnover      Boolean         @default(false) @map("is_rental_turnover")
  priorTenantName       String?         @map("prior_tenant_name")
  turnoverStartedAt     DateTime?       @map("turnover_started_at")
  turnoverCompletedAt   DateTime?       @map("turnover_completed_at")
  createdAt             DateTime        @default(now()) @map("created_at")
  updatedAt             DateTime        @updatedAt @map("updated_at")

  lead           Lead     @relation(fields: [leadId], references: [id])
  currentStage   JobStage @relation(fields: [currentStageId], references: [id])
  projectManager User?    @relation("ProjectManager", fields: [projectManagerId], references: [id])
  salesRep       User?    @relation("SalesRep", fields: [salesRepId], references: [id])

  stageHistory       JobStageHistory[]
  permits            JobPermit[]
  crewAssignments    CrewAssignment[]
  inspections        Inspection[]
  payments           Payment[]
  invoices           Invoice[]
  expenses           JobExpense[]
  tasks              Task[]
  reviewRequests     ReviewRequest[]
  referrals          Referral[]
  laborContracts     LaborContract[]
  budgetLines        BudgetLine[]
  generatedDocuments GeneratedDocument[]
  changeOrders       ChangeOrder[]

  @@index([leadId])
  @@index([currentStageId])
  @@index([salesRepId])
  @@index([projectManagerId])
  @@index([scheduledDate])
  @@index([isRentalTurnover])
  @@map("jobs")
}

model JobStageHistory {
  id              String   @id @default(cuid())
  jobId           String   @map("job_id")
  fromStageId     String?  @map("from_stage_id")
  toStageId       String   @map("to_stage_id")
  changedByUserId String   @map("changed_by_user_id")
  changedAt       DateTime @default(now()) @map("changed_at")
  reason          String?

  job       Job       @relation(fields: [jobId], references: [id], onDelete: Cascade)
  fromStage JobStage? @relation("JobFromStage", fields: [fromStageId], references: [id])
  toStage   JobStage  @relation("JobToStage", fields: [toStageId], references: [id])
  changedBy User      @relation("JobChangedByUser", fields: [changedByUserId], references: [id])

  @@index([jobId])
  @@map("job_stage_history")
}

// ─── CRM 2.0: Permits (Job-linked) ─────────────────────────────────────────

model JobPermit {
  id                   String       @id @default(cuid())
  jobId                String       @map("job_id")
  municipality         String
  permitType           String?      @map("permit_type")
  permitNumber         String?      @map("permit_number")
  submittedDate        DateTime?    @map("submitted_date")
  expectedApprovalDate DateTime?    @map("expected_approval_date")
  approvedDate         DateTime?    @map("approved_date")
  expirationDate       DateTime?    @map("expiration_date")
  status               PermitStatus @default(APPLIED)
  assignedUserId       String?      @map("assigned_user_id")
  inspectorName        String?      @map("inspector_name")
  permitFee            Decimal?     @map("permit_fee") @db.Decimal(10, 2)
  notes                String?      @db.Text
  finalPassedDate      DateTime?    @map("final_passed_date")
  createdAt            DateTime     @default(now()) @map("created_at")
  updatedAt            DateTime     @updatedAt @map("updated_at")

  job                Job                   @relation(fields: [jobId], references: [id], onDelete: Cascade)
  assignedTo         User?                 @relation("PermitAssignedUser", fields: [assignedUserId], references: [id])
  followUpExecutions FollowUpExecution[]
  inspections        JobPermitInspection[]

  @@index([jobId])
  @@index([status])
  @@map("job_permits")
}

model JobPermitInspection {
  id            String                 @id @default(cuid())
  permitId      String                 @map("permit_id")
  type          PermitInspectionType   @default(OTHER)
  scheduledFor  DateTime?              @map("scheduled_for")
  completedAt   DateTime?              @map("completed_at")
  result        PermitInspectionResult @default(SCHEDULED)
  inspectorName String?                @map("inspector_name")
  notes         String?                @db.Text
  createdAt     DateTime               @default(now()) @map("created_at")
  updatedAt     DateTime               @updatedAt @map("updated_at")

  permit             JobPermit           @relation(fields: [permitId], references: [id], onDelete: Cascade)
  followUpExecutions FollowUpExecution[]

  @@index([permitId])
  @@index([scheduledFor])
  @@map("job_permit_inspections")
}

// ─── CRM 2.0: Crews + Scheduling ───────────────────────────────────────────

model Crew {
  id        String   @id @default(cuid())
  name      String
  phone     String?
  email     String?
  trades    String[] @default([])
  counties  String[] @default([])
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  assignments    CrewAssignment[]
  laborContracts LaborContract[]

  @@map("crews")
}

model CrewAssignment {
  id           String    @id @default(cuid())
  jobId        String    @map("job_id")
  crewId       String    @map("crew_id")
  assignedDate DateTime  @default(now()) @map("assigned_date")
  installDate  DateTime? @map("install_date")

  job  Job  @relation(fields: [jobId], references: [id], onDelete: Cascade)
  crew Crew @relation(fields: [crewId], references: [id])

  @@index([jobId])
  @@index([crewId])
  @@map("crew_assignments")
}

// ─── CRM 2.0: Labor contracts (owner → crew, for rollup jobs) ──────────────

model LaborContract {
  id                      String    @id @default(cuid())
  jobId                   String    @map("job_id")
  crewId                  String?   @map("crew_id") // null for ad-hoc/typed labor lines
  label                   String? // ad-hoc name when no crew selected
  contractAmount          Decimal   @map("contract_amount") @db.Decimal(12, 2)
  description             String?   @db.Text
  // Optional contract-detail fields surfaced on generated contract PDFs.
  paymentTerms            String?   @map("payment_terms") @db.Text
  startDate               DateTime? @map("start_date")
  estimatedCompletionDate DateTime? @map("estimated_completion_date")
  contractorLicense       String?   @map("contractor_license")
  contractorInsurance     String?   @map("contractor_insurance") @db.Text
  exclusions              String?   @db.Text
  notes                   String?   @db.Text
  retainagePercent        Decimal?  @map("retainage_percent") @db.Decimal(5, 2)
  retainageReleased       Boolean   @default(false) @map("retainage_released")
  retainageReleasedDate   DateTime? @map("retainage_released_date")
  delayDamagesPerDay      Decimal?  @map("delay_damages_per_day") @db.Decimal(12, 2)
  createdByUserId         String    @map("created_by_user_id")
  createdAt               DateTime  @default(now()) @map("created_at")
  updatedAt               DateTime  @updatedAt @map("updated_at")

  job                  Job                 @relation(fields: [jobId], references: [id], onDelete: Cascade)
  crew                 Crew?               @relation(fields: [crewId], references: [id])
  createdBy            User                @relation(fields: [createdByUserId], references: [id])
  payments             LaborPayment[]
  changeOrders         LaborChangeOrder[]
  customerChangeOrders ChangeOrder[]
  budgetAllocations    BudgetAllocation[]
  generatedDocuments   GeneratedDocument[]
  tasks                LaborContractTask[]

  @@index([jobId])
  @@map("labor_contracts")
}

// Task / payment-schedule line items for a labor contract (interior renovation).
model LaborContractTask {
  id                 String    @id @default(cuid())
  laborContractId    String    @map("labor_contract_id")
  sortOrder          Int       @default(0) @map("sort_order")
  name               String
  room               String?
  description        String?   @db.Text
  paymentAmount      Decimal?  @map("payment_amount") @db.Decimal(12, 2)
  paymentPercent     Decimal?  @map("payment_percent") @db.Decimal(5, 2)
  inspectionRequired Boolean   @default(true) @map("inspection_required")
  inspectionStatus   String    @default("PENDING") @map("inspection_status") // PENDING | PASSED | FAILED | NA
  status             String    @default("NOT_STARTED") // NOT_STARTED | IN_PROGRESS | COMPLETE
  approvedBy         String?   @map("approved_by")
  approvedDate       DateTime? @map("approved_date")
  notes              String?   @db.Text
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  laborContract LaborContract @relation(fields: [laborContractId], references: [id], onDelete: Cascade)

  @@index([laborContractId])
  @@map("labor_contract_tasks")
}

model BudgetLine {
  id        String   @id @default(cuid())
  jobId     String   @map("job_id")
  category  String?
  name      String
  amount    Decimal  @db.Decimal(12, 2)
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  job         Job                @relation(fields: [jobId], references: [id], onDelete: Cascade)
  allocations BudgetAllocation[]

  @@index([jobId])
  @@map("budget_lines")
}

model BudgetAllocation {
  id              String   @id @default(cuid())
  budgetLineId    String   @map("budget_line_id")
  expenseId       String?  @map("expense_id")
  laborContractId String?  @map("labor_contract_id")
  amount          Decimal  @db.Decimal(12, 2)
  createdAt       DateTime @default(now()) @map("created_at")

  budgetLine    BudgetLine     @relation(fields: [budgetLineId], references: [id], onDelete: Cascade)
  expense       JobExpense?    @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  laborContract LaborContract? @relation(fields: [laborContractId], references: [id], onDelete: Cascade)

  @@index([budgetLineId])
  @@index([expenseId])
  @@index([laborContractId])
  @@map("budget_allocations")
}

model LaborChangeOrder {
  id                  String   @id @default(cuid())
  laborContractId     String   @map("labor_contract_id")
  amount              Decimal  @db.Decimal(12, 2) // signed: positive add, negative credit (price adjustment)
  reason              String?  @db.Text
  changeDate          DateTime @default(now()) @map("change_date")
  // Optional addendum-detail fields surfaced on generated addendum PDFs.
  changeNumber        Int?     @map("change_number")
  scopeChange         String?  @map("scope_change") @db.Text
  addedScope          String?  @map("added_scope") @db.Text
  removedScope        String?  @map("removed_scope") @db.Text
  timeAdjustmentDays  Int?     @map("time_adjustment_days")
  updatedPaymentTerms String?  @map("updated_payment_terms") @db.Text
  paymentImpact       String?  @map("payment_impact") @db.Text
  retainageImpact     String?  @map("retainage_impact") @db.Text
  createdByUserId     String   @map("created_by_user_id")
  createdAt           DateTime @default(now()) @map("created_at")

  laborContract      LaborContract       @relation(fields: [laborContractId], references: [id], onDelete: Cascade)
  createdBy          User                @relation(fields: [createdByUserId], references: [id])
  generatedDocuments GeneratedDocument[]
  changeOrder        ChangeOrder?

  @@index([laborContractId])
  @@map("labor_change_orders")
}

// Customer-facing change order. Emailed to the homeowner as a branded bill;
// they approve/reject via a no-login token link. On approval it bills the
// customer (contract/balance + invoice) and, when a crew cost + labor contract
// are set, creates a linked LaborChangeOrder so crew labor rollup stays correct.
model ChangeOrder {
  id                 String            @id @default(cuid())
  jobId              String            @map("job_id")
  laborContractId    String?           @map("labor_contract_id") // optional crew link
  number             Int // sequential per job
  title              String?
  description        String?           @db.Text // scope shown to the customer
  customerPrice      Decimal           @map("customer_price") @db.Decimal(12, 2) // what the owner is billed
  crewCost           Decimal?          @map("crew_cost") @db.Decimal(12, 2) // optional internal cost delta (signed)
  status             ChangeOrderStatus @default(DRAFT)
  // Customer approval (no-login token flow)
  token              String?           @unique
  tokenExpiresAt     DateTime?         @map("token_expires_at")
  sentAt             DateTime?         @map("sent_at")
  decidedAt          DateTime?         @map("decided_at")
  decisionName       String?           @map("decision_name") // typed name on approve/reject
  decisionIp         String?           @map("decision_ip")
  rejectionReason    String?           @map("rejection_reason") @db.Text
  // Links created on approval
  invoiceId          String?           @unique @map("invoice_id")
  laborChangeOrderId String?           @unique @map("labor_change_order_id")
  createdByUserId    String            @map("created_by_user_id")
  createdAt          DateTime          @default(now()) @map("created_at")
  updatedAt          DateTime          @updatedAt @map("updated_at")

  job              Job               @relation(fields: [jobId], references: [id], onDelete: Cascade)
  laborContract    LaborContract?    @relation(fields: [laborContractId], references: [id], onDelete: SetNull)
  invoice          Invoice?          @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  laborChangeOrder LaborChangeOrder? @relation(fields: [laborChangeOrderId], references: [id], onDelete: SetNull)
  createdBy        User              @relation(fields: [createdByUserId], references: [id])

  @@index([jobId])
  @@index([status])
  @@map("change_orders")
}

model GeneratedDocument {
  id                 String                @id @default(cuid())
  jobId              String                @map("job_id")
  laborContractId    String?               @map("labor_contract_id")
  changeOrderId      String?               @map("change_order_id")
  documentType       GeneratedDocumentType @map("document_type")
  versionNumber      Int                   @map("version_number")
  fileName           String                @map("file_name")
  storageKey         String                @map("storage_key")
  fileId             String?               @map("file_id")
  generatedByUserId  String                @map("generated_by_user_id")
  generatedAt        DateTime              @default(now()) @map("generated_at")
  sourceDataSnapshot Json                  @map("source_data_snapshot")

  job           Job               @relation(fields: [jobId], references: [id], onDelete: Cascade)
  laborContract LaborContract?    @relation(fields: [laborContractId], references: [id], onDelete: SetNull)
  changeOrder   LaborChangeOrder? @relation(fields: [changeOrderId], references: [id], onDelete: SetNull)
  file          File?             @relation(fields: [fileId], references: [id], onDelete: SetNull)
  generatedBy   User              @relation(fields: [generatedByUserId], references: [id])

  @@index([jobId])
  @@index([laborContractId])
  @@index([changeOrderId])
  @@map("generated_documents")
}

model LaborPayment {
  id              String         @id @default(cuid())
  laborContractId String         @map("labor_contract_id")
  amount          Decimal        @db.Decimal(12, 2)
  paidDate        DateTime       @default(now()) @map("paid_date")
  method          PaymentMethod?
  reference       String?
  notes           String?        @db.Text
  createdByUserId String         @map("created_by_user_id")
  createdAt       DateTime       @default(now()) @map("created_at")

  laborContract LaborContract @relation(fields: [laborContractId], references: [id], onDelete: Cascade)
  createdBy     User          @relation(fields: [createdByUserId], references: [id])

  @@index([laborContractId])
  @@map("labor_payments")
}

// ─── CRM 2.0: Inspections ──────────────────────────────────────────────────

model Inspection {
  id            String           @id @default(cuid())
  jobId         String           @map("job_id")
  type          String
  scheduledDate DateTime?        @map("scheduled_date")
  result        InspectionResult @default(PENDING)
  notes         String?          @db.Text
  inspectorId   String?          @map("inspector_id")
  createdAt     DateTime         @default(now()) @map("created_at")
  updatedAt     DateTime         @updatedAt @map("updated_at")

  job       Job   @relation(fields: [jobId], references: [id], onDelete: Cascade)
  inspector User? @relation(fields: [inspectorId], references: [id])

  @@index([jobId])
  @@map("inspections")
}

// ─── CRM 2.0: Payments ─────────────────────────────────────────────────────

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  VOID
}

enum ChangeOrderStatus {
  DRAFT
  SENT
  APPROVED
  REJECTED
  VOID
}

model PaymentSource {
  id        String   @id @default(cuid())
  name      String   @unique
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("payment_sources")
}

enum JobExpenseType {
  MATERIAL
  LABOR
  EQUIPMENT
  PERMIT_FEE
  SUBCONTRACTOR
  CHANGE_ORDER
  OTHER
}

model JobExpense {
  id              String         @id @default(cuid())
  jobId           String         @map("job_id")
  type            JobExpenseType @default(OTHER)
  vendor          String?
  description     String?        @db.Text
  amount          Decimal        @db.Decimal(12, 2)
  incurredDate    DateTime       @default(now()) @map("incurred_date")
  paidMethod      PaymentMethod? @map("paid_method")
  paidFrom        String?        @map("paid_from")
  billable        Boolean        @default(false)
  createdByUserId String         @map("created_by_user_id")
  // Idempotency key for upstream integrations (cc-allocator sends txn.id).
  // Nullable so manually-created expenses are unaffected.
  externalId      String?        @unique @map("external_id")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  job               Job                @relation(fields: [jobId], references: [id], onDelete: Cascade)
  createdBy         User               @relation(fields: [createdByUserId], references: [id])
  budgetAllocations BudgetAllocation[]

  @@index([jobId])
  @@index([type])
  @@map("job_expenses")
}

model Invoice {
  id            String        @id @default(cuid())
  jobId         String        @map("job_id")
  invoiceNumber String        @unique @map("invoice_number")
  issueDate     DateTime      @default(now()) @map("issue_date")
  dueDate       DateTime?     @map("due_date")
  amount        Decimal       @db.Decimal(12, 2)
  status        InvoiceStatus @default(DRAFT)
  paidAt        DateTime?     @map("paid_at")
  notes         String?       @db.Text
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  job         Job          @relation(fields: [jobId], references: [id], onDelete: Cascade)
  changeOrder ChangeOrder?
  payments    Payment[]

  @@index([jobId])
  @@index([status])
  @@map("invoices")
}

model Payment {
  id           String         @id @default(cuid())
  jobId        String         @map("job_id")
  paymentType  PaymentType    @map("payment_type")
  method       PaymentMethod?
  reference    String?
  amount       Decimal        @db.Decimal(12, 2)
  status       PaymentStatus  @default(PENDING)
  dueDate      DateTime?      @map("due_date")
  receivedDate DateTime?      @map("received_date")
  invoiceId    String?        @map("invoice_id")
  notes        String?        @db.Text
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")

  job     Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  invoice Invoice? @relation(fields: [invoiceId], references: [id], onDelete: SetNull)

  @@index([jobId])
  @@index([status])
  @@index([invoiceId])
  @@map("payments")
}

// ─── CRM 2.0: Reviews + Referrals ──────────────────────────────────────────

model ReviewRequest {
  id          String       @id @default(cuid())
  jobId       String       @map("job_id")
  leadId      String       @map("lead_id")
  platform    String       @default("Google")
  status      ReviewStatus @default(PENDING)
  sentAt      DateTime?    @map("sent_at")
  completedAt DateTime?    @map("completed_at")
  reviewUrl   String?      @map("review_url")
  rating      Int?
  createdAt   DateTime     @default(now()) @map("created_at")

